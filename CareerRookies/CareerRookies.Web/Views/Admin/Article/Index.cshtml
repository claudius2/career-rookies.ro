@using CareerRookies.Web.ViewModels
@using CareerRookies.Web.Models
@model PagedResult<Article>
@{
    ViewData["Title"] = "Gestionare Articole";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Articole</h1>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row g-3">
            @foreach (var article in Model.Items)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body py-3">
                            <div class="row align-items-center">
                                <!-- Info -->
                                <div class="col-lg-5">
                                    <h6 class="mb-1 fw-bold">@article.Title</h6>
                                    <small class="text-muted">
                                        <i class="bi bi-person me-1"></i>@article.AuthorName
                                        <span class="mx-1">·</span>
                                        <i class="bi bi-calendar3 me-1"></i>@article.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                    </small>
                                </div>

                                <!-- Status -->
                                <div class="col-lg-3 mt-2 mt-lg-0">
                                    @switch (article.Status)
                                    {
                                        case ArticleStatus.Approved:
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Aprobat</span>
                                            break;
                                        case ArticleStatus.Rejected:
                                            <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Respins</span>
                                            break;
                                        default:
                                            <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>În așteptare</span>
                                            break;
                                    }
                                </div>

                                <!-- Actions -->
                                <div class="col-lg-4 mt-2 mt-lg-0 text-lg-end">
                                    @if (article.Status != ArticleStatus.Approved)
                                    {
                                        <form action="/Admin/Articles/Approve/@article.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Aprobă">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (article.Status != ArticleStatus.Rejected)
                                    {
                                        <form action="/Admin/Articles/Reject/@article.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Respinge">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    <form action="/Admin/Articles/Delete/@article.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Sigur doriti sa stergeti acest articol?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="mt-3">
            <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-file-earmark-text fs-1 d-block mb-3"></i>
            <p>Nu exista articole.</p>
        </div>
    }
</div>
