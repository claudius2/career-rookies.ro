@using CareerRookies.Web.ViewModels
@model PagedResult<Testimonial>
@{
    ViewData["Title"] = "Gestionare Testimoniale";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Testimoniale</h1>
        <a href="/Admin/Testimonials/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Adaugă
        </a>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row g-3">
            @foreach (var testimonial in Model.Items)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body py-3">
                            <div class="row align-items-center">
                                <!-- Info -->
                                <div class="col-lg-5">
                                    <p class="mb-1 small fst-italic" title="@testimonial.Text">
                                        "@(testimonial.Text.Length > 120 ? testimonial.Text[..120] + "..." : testimonial.Text)"
                                    </p>
                                    <small class="text-muted">
                                        <i class="bi bi-person me-1"></i><strong>@testimonial.AuthorName</strong>
                                    </small>
                                </div>

                                <!-- Status & Type -->
                                <div class="col-lg-3 mt-2 mt-lg-0">
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        @switch (testimonial.AuthorType)
                                        {
                                            case AuthorType.Student:
                                                <span class="badge bg-primary">Elev</span>
                                                break;
                                            case AuthorType.Speaker:
                                                <span class="badge bg-info">Speaker</span>
                                                break;
                                        }
                                        @if (testimonial.IsApproved)
                                        {
                                            <span class="badge bg-success">Aprobat</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">În așteptare</span>
                                        }
                                        <small class="text-muted">Ordine: @testimonial.SortOrder</small>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="col-lg-4 mt-2 mt-lg-0 text-lg-end">
                                    @if (!testimonial.IsApproved)
                                    {
                                        <form action="/Admin/Testimonials/Approve/@testimonial.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Aprobă">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    <a href="/Admin/Testimonials/Edit/@testimonial.Id" class="btn btn-sm btn-outline-primary" title="Editează">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form action="/Admin/Testimonials/Delete/@testimonial.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Sigur doriti sa stergeti acest testimonial?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="mt-3">
            <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-chat-quote fs-1 d-block mb-3"></i>
            <p>Nu exista testimoniale. Adaugați primul testimonial.</p>
        </div>
    }
</div>
