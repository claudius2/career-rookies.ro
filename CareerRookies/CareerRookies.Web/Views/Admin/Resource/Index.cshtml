@using CareerRookies.Web.ViewModels
@model PagedResult<CareerResource>
@{
    ViewData["Title"] = "Gestionare Resurse";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Resurse</h1>
        <a href="/Admin/Resources/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Adaugă
        </a>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row g-3">
            @foreach (var resource in Model.Items)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body py-3">
                            <div class="row align-items-center">
                                <!-- Info -->
                                <div class="col-lg-5">
                                    <h6 class="mb-1 fw-bold">@resource.Name</h6>
                                    <small class="text-muted">
                                        <a href="@resource.Url" target="_blank" rel="noopener noreferrer" class="text-decoration-none text-muted">
                                            <i class="bi bi-link-45deg me-1"></i>@(resource.Url.Length > 50 ? resource.Url[..50] + "..." : resource.Url)
                                            <i class="bi bi-box-arrow-up-right ms-1" style="font-size: 0.7rem;"></i>
                                        </a>
                                    </small>
                                </div>

                                <!-- Category & Order -->
                                <div class="col-lg-3 mt-2 mt-lg-0">
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        @switch (resource.Category)
                                        {
                                            case ResourceCategory.UniversityFair:
                                                <span class="badge bg-primary">Târg Universități</span>
                                                break;
                                            case ResourceCategory.GuidanceFirm:
                                                <span class="badge bg-success">Firmă Orientare</span>
                                                break;
                                            case ResourceCategory.EUProject:
                                                <span class="badge bg-info">Proiect EU</span>
                                                break;
                                        }
                                        <small class="text-muted">Ordine: @resource.SortOrder</small>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="col-lg-4 mt-2 mt-lg-0 text-lg-end">
                                    <a href="/Admin/Resources/Edit/@resource.Id" class="btn btn-sm btn-outline-primary" title="Editează">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form action="/Admin/Resources/Delete/@resource.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Sigur doriti sa stergeti aceasta resursa?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="mt-3">
            <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-link-45deg fs-1 d-block mb-3"></i>
            <p>Nu exista resurse. Adaugați prima resursă.</p>
        </div>
    }
</div>
