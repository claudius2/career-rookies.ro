@using CareerRookies.Web.ViewModels
@model PagedResult<CareerResource>
@{
    ViewData["Title"] = "Gestionare Resurse";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Gestionare Resurse</h1>
        <a href="/Admin/Resources/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Adauga
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Inchide"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Nume</th>
                                <th>URL</th>
                                <th>Categorie</th>
                                <th>Ordine</th>
                                <th class="text-end">Actiuni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var resource in Model.Items)
                            {
                                <tr>
                                    <td>@resource.Name</td>
                                    <td>
                                        <a href="@resource.Url" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                                            @(resource.Url.Length > 50 ? resource.Url[..50] + "..." : resource.Url)
                                            <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                        </a>
                                    </td>
                                    <td>
                                        @switch (resource.Category)
                                        {
                                            case ResourceCategory.UniversityFair:
                                                <span class="badge bg-primary">Targ Universitati</span>
                                                break;
                                            case ResourceCategory.GuidanceFirm:
                                                <span class="badge bg-success">Firma Orientare</span>
                                                break;
                                            case ResourceCategory.EUProject:
                                                <span class="badge bg-info">Proiect EU</span>
                                                break;
                                        }
                                    </td>
                                    <td>@resource.SortOrder</td>
                                    <td class="text-end">
                                        <a href="/Admin/Resources/Edit/@resource.Id"
                                           class="btn btn-sm btn-outline-primary" title="Editeaza">
                                            <i class="bi bi-pencil"></i> Editeaza
                                        </a>
                                        <form action="/Admin/Resources/Delete/@resource.Id"
                                              method="post" class="d-inline ms-1"
                                              onsubmit="return confirm('Sigur doriti sa stergeti aceasta resursa?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sterge">
                                                <i class="bi bi-trash"></i> Sterge
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-link-45deg fs-1 d-block mb-3"></i>
                    <p>Nu exista resurse. Adaugati prima resursa.</p>
                </div>
            }
        </div>
    </div>
</div>
