@model List<SiteSetting>
@{
    ViewData["Title"] = "Setari Site";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Setari Site</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Inchide"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <form action="/Admin/Settings/Update" method="post">
                    @Html.AntiForgeryToken()
                    @foreach (var setting in Model)
                    {
                        <div class="row mb-3 align-items-center">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold mb-0">@setting.Key</label>
                            </div>
                            <div class="col-md-8">
                                @if (setting.Value.Equals("true", StringComparison.OrdinalIgnoreCase) ||
                                     setting.Value.Equals("false", StringComparison.OrdinalIgnoreCase))
                                {
                                    <div class="form-check form-switch">
                                        <input type="hidden" name="settings[@setting.Key]" value="false" />
                                        <input class="form-check-input" type="checkbox"
                                               name="settings[@setting.Key]" value="true" id="setting_@setting.Key"
                                               @(setting.Value.Equals("true", StringComparison.OrdinalIgnoreCase) ? "checked" : "") />
                                        <label class="form-check-label" for="setting_@setting.Key">
                                            @(setting.Value.Equals("true", StringComparison.OrdinalIgnoreCase) ? "Activ" : "Inactiv")
                                        </label>
                                    </div>
                                }
                                else
                                {
                                    <input type="text" name="settings[@setting.Key]" value="@setting.Value" class="form-control" />
                                }
                            </div>
                        </div>
                    }

                    <hr class="my-4" />

                    <div class="d-flex">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Salveaza setarile
                        </button>
                    </div>
                </form>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-gear fs-1 d-block mb-3"></i>
                    <p>Nu exista setari configurate.</p>
                </div>
            }
        </div>
    </div>
</div>
