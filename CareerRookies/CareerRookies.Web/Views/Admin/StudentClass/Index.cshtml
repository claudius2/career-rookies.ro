@model List<StudentClass>
@{
    ViewData["Title"] = "Gestionare Clase";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Clase elevi</h1>
        <a href="/Admin/StudentClasses/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Adaugă
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var sc in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body py-3">
                            <div class="row align-items-center">
                                <!-- Info -->
                                <div class="col-lg-5">
                                    <h6 class="mb-0 fw-bold">@sc.Name</h6>
                                </div>

                                <!-- Status -->
                                <div class="col-lg-3 mt-2 mt-lg-0">
                                    @if (sc.IsActive)
                                    {
                                        <span class="badge bg-success">Activă</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivă</span>
                                    }
                                </div>

                                <!-- Actions -->
                                <div class="col-lg-4 mt-2 mt-lg-0 text-lg-end">
                                    <a href="/Admin/StudentClasses/Edit/@sc.Id" class="btn btn-sm btn-outline-primary" title="Editează">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form action="/Admin/StudentClasses/Delete/@sc.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Sigur doriti sa stergeti aceasta clasa?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-mortarboard fs-1 d-block mb-3"></i>
            <p>Nu exista clase. Adaugați prima clasă.</p>
        </div>
    }
</div>
