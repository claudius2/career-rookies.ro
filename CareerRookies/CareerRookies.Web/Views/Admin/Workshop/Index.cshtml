@using CareerRookies.Web.ViewModels
@model PagedResult<Workshop>
@{
    ViewData["Title"] = "Gestionare Workshop-uri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Workshop-uri</h1>
        <a href="/Admin/Workshops/Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Adauga
        </a>
    </div>

    @if (Model.Items.Any())
    {
        <div class="row g-3">
            @foreach (var workshop in Model.Items)
            {
                var isPast = workshop.Date <= DateTime.UtcNow;
                var regCount = workshop.Registrations.Count;
                <div class="col-12">
                    <div class="card border-0 shadow-sm @(isPast ? "opacity-75" : "")">
                        <div class="card-body py-3">
                            <div class="row align-items-center">
                                <!-- Info -->
                                <div class="col-lg-5">
                                    <h6 class="mb-1 fw-bold">@workshop.Title</h6>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i>@workshop.Date.ToString("dd.MM.yyyy HH:mm")
                                        @if (isPast)
                                        {
                                            <span class="badge bg-secondary ms-1">Trecut</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success ms-1">Viitor</span>
                                        }
                                    </small>
                                    @if (!string.IsNullOrEmpty(workshop.SpeakerNames))
                                    {
                                        <div class="mt-1">
                                            <small class="text-muted"><i class="bi bi-person me-1"></i>@workshop.SpeakerNames</small>
                                        </div>
                                    }
                                </div>

                                <!-- Stats -->
                                <div class="col-lg-3 mt-2 mt-lg-0">
                                    <div class="d-flex gap-3">
                                        <div class="text-center">
                                            <div class="fw-bold @(regCount > 0 ? "text-primary" : "text-muted")">@regCount</div>
                                            <small class="text-muted">Înscriși</small>
                                        </div>
                                        <div class="text-center">
                                            <div class="fw-bold text-muted">
                                                @(workshop.MaxCapacity.HasValue ? workshop.MaxCapacity.ToString() : "∞")
                                            </div>
                                            <small class="text-muted">Capacitate</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Actions -->
                                <div class="col-lg-4 mt-2 mt-lg-0 text-lg-end">
                                    <a href="/Admin/Workshops/Edit/@workshop.Id" class="btn btn-sm btn-outline-primary" title="Editează">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/Admin/Workshops/Registrations/@workshop.Id" class="btn btn-sm btn-outline-info position-relative" title="Înregistrări">
                                        <i class="bi bi-people"></i>
                                        @if (regCount > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size: 0.6rem;">
                                                @regCount
                                            </span>
                                        }
                                    </a>
                                    <a href="/Admin/Workshops/Media/@workshop.Id" class="btn btn-sm btn-outline-secondary" title="Media">
                                        <i class="bi bi-images"></i>
                                    </a>
                                    <form action="/Admin/Workshops/Delete/@workshop.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Sigur doriti sa stergeti acest workshop?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Șterge">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="mt-3">
            <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
            <p>Nu exista workshop-uri. Adaugati primul workshop.</p>
        </div>
    }
</div>
