@using CareerRookies.Web.ViewModels
@model PagedResult<Workshop>
@{
    ViewData["Title"] = "Gestionare Workshop-uri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Gestionare Workshop-uri</h1>
        <a href="/Admin/Workshops/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Adauga Workshop
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Inchide"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            @if (Model.Items.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Titlu</th>
                                <th>Data</th>
                                <th>Speaker</th>
                                <th>Capacitate</th>
                                <th class="text-end">Actiuni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var workshop in Model.Items)
                            {
                                <tr>
                                    <td>@workshop.Title</td>
                                    <td>@workshop.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@workshop.SpeakerNames</td>
                                    <td>
                                        @if (workshop.MaxCapacity.HasValue)
                                        {
                                            <span>@workshop.MaxCapacity</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Nelimitat</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="/Admin/Workshops/Edit/@workshop.Id"
                                               class="btn btn-outline-primary" title="Editeaza">
                                                <i class="bi bi-pencil"></i> Editeaza
                                            </a>
                                            <a href="/Admin/Workshops/Registrations/@workshop.Id"
                                               class="btn btn-outline-info" title="Inregistrari">
                                                <i class="bi bi-people"></i> Inregistrari
                                            </a>
                                            <a href="/Admin/Workshops/Media/@workshop.Id"
                                               class="btn btn-outline-secondary" title="Media">
                                                <i class="bi bi-images"></i> Media
                                            </a>
                                        </div>
                                        <form action="/Admin/Workshops/Delete/@workshop.Id"
                                              method="post" class="d-inline ms-1"
                                              onsubmit="return confirm('Sigur doriti sa stergeti acest workshop?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sterge">
                                                <i class="bi bi-trash"></i> Sterge
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Index", (string?)null, (object?)null)" />
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
                    <p>Nu exista workshop-uri. Adaugati primul workshop.</p>
                </div>
            }
        </div>
    </div>
</div>
