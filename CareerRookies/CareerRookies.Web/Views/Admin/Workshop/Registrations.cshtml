@model Workshop
@{
    ViewData["Title"] = "Inregistrari - " + Model.Title;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Inregistrari</h1>
            <p class="text-muted mb-0">Workshop: <strong>@Model.Title</strong></p>
        </div>
        <div class="btn-group">
            <a href="/Admin/Workshops/Registrations/@Model.Id/Export" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Export CSV
            </a>
            <a href="/Admin/Workshops" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Inapoi la workshop-uri
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model.Registrations.Any())
            {
                <div class="mb-3">
                    <span class="badge bg-info fs-6">
                        Total inregistrari: @Model.Registrations.Count
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Nume Student</th>
                                <th>Clasa</th>
                                <th>Consimtamant GDPR</th>
                                <th>Data inregistrarii</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var index = 1; }
                            @foreach (var reg in Model.Registrations.OrderByDescending(r => r.CreatedAt))
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@reg.StudentName</td>
                                    <td>@reg.StudentClass?.Name</td>
                                    <td>
                                        @if (reg.GdprConsentAccepted)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> Da</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-lg"></i> Nu</span>
                                        }
                                    </td>
                                    <td>@reg.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-people fs-1 d-block mb-3"></i>
                    <p>Nu exista inregistrari pentru acest workshop.</p>
                </div>
            }
        </div>
    </div>
</div>
