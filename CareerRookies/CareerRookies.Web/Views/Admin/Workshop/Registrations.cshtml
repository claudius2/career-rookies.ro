@model Workshop
@{
    ViewData["Title"] = "Înregistrări - " + Model.Title;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 mb-1">Înregistrări</h1>
            <small class="text-muted">@Model.Title — @Model.Registrations.Count înscriși
                @if (Model.MaxCapacity.HasValue)
                {
                    @: / @Model.MaxCapacity locuri
                }
            </small>
        </div>
        <div class="d-flex gap-2">
            @if (Model.Registrations.Any())
            {
                <a href="/Admin/Workshops/Registrations/@Model.Id/Export" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-download me-1"></i> Export CSV
                </a>
            }
            <a href="/Admin/Workshops" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Înapoi
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model.Registrations.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 40px;">#</th>
                                <th>Nume</th>
                                <th>Clasa</th>
                                <th>GDPR</th>
                                <th>Data</th>
                                <th style="width: 60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var index = 1; }
                            @foreach (var reg in Model.Registrations.OrderByDescending(r => r.CreatedAt))
                            {
                                <tr>
                                    <td class="text-muted">@index</td>
                                    <td class="fw-semibold">@reg.StudentName</td>
                                    <td>@(reg.StudentClass?.Name ?? "—")</td>
                                    <td>
                                        @if (reg.GdprConsentAccepted)
                                        {
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle-fill text-danger"></i>
                                        }
                                    </td>
                                    <td><small class="text-muted">@reg.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small></td>
                                    <td>
                                        <form action="/Admin/Workshops/Registrations/@Model.Id/Delete/@reg.Id"
                                              method="post"
                                              onsubmit="return confirm('Sigur doriti sa stergeti înregistrarea lui @reg.StudentName?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Șterge">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-people fs-1 d-block mb-3"></i>
                    <p>Nu exista înregistrări pentru acest workshop.</p>
                </div>
            }
        </div>
    </div>
</div>
