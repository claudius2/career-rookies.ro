@model CareerRookies.Web.ViewModels.Admin.WorkshopFormViewModel
@{
    ViewData["Title"] = "Adauga Workshop";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Adauga Workshop</h1>
        <a href="/Admin/Workshops" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Inapoi la lista
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <form action="/Admin/Workshops/Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" placeholder="Titlul workshop-ului" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" id="workshop-description" class="form-control" rows="5" placeholder="Descrierea workshop-ului"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label asp-for="Date" class="form-label"></label>
                            <input asp-for="Date" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MaxCapacity" class="form-label"></label>
                            <input asp-for="MaxCapacity" type="number" class="form-control" min="0" placeholder="Lasati gol pentru nelimitat" />
                            <span asp-validation-for="MaxCapacity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Image" class="form-label">Imagine workshop</label>
                            <input asp-for="Image" class="form-control" accept="image/*" />
                            <span asp-validation-for="Image" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Speakeri</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="addSpeakerBtn">
                        <i class="bi bi-plus-lg me-1"></i> Adauga speaker
                    </button>
                </div>

                <div id="speakersContainer">
                    @for (int i = 0; i < Model.Speakers.Count; i++)
                    {
                        <div class="speaker-item card mb-3" data-index="@i">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">Speaker #<span class="speaker-number">@(i + 1)</span></h6>
                                    @if (i > 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-speaker">
                                            <i class="bi bi-trash"></i> Sterge
                                        </button>
                                    }
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Nume speaker</label>
                                            <input name="Speakers[@i].Name" value="@Model.Speakers[i].Name" class="form-control" placeholder="Numele speaker-ului" required />
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Descriere speaker</label>
                                            <textarea name="Speakers[@i].Description" class="form-control" rows="4" placeholder="Descrierea speaker-ului" required>@Model.Speakers[i].Description</textarea>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label class="form-label">Imagine speaker</label>
                                            <input name="Speakers[@i].Image" type="file" class="form-control" accept="image/*" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Salveaza
                    </button>
                    <a href="/Admin/Workshops" class="btn btn-outline-secondary">Anuleaza</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/tinymce@7/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: '#workshop-description',
            language: 'ro',
            height: 300,
            menubar: false,
            plugins: 'lists link autolink wordcount',
            toolbar: 'undo redo | blocks | bold italic underline | bullist numlist | link | removeformat',
            block_formats: 'Paragraph=p; Heading 3=h3; Heading 4=h4; Blockquote=blockquote',
            content_style: 'body { font-family: "Open Sans", sans-serif; font-size: 14px; }',
            branding: false,
            promotion: false,
            setup: function (editor) {
                editor.on('change', function () { editor.save(); });
            }
        });

        // Dynamic speaker management
        document.getElementById('addSpeakerBtn').addEventListener('click', function () {
            var container = document.getElementById('speakersContainer');
            var index = container.querySelectorAll('.speaker-item').length;
            var html = `
                <div class="speaker-item card mb-3" data-index="${index}">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Speaker #<span class="speaker-number">${index + 1}</span></h6>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-speaker">
                                <i class="bi bi-trash"></i> Sterge
                            </button>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Nume speaker</label>
                                    <input name="Speakers[${index}].Name" class="form-control" placeholder="Numele speaker-ului" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Descriere speaker</label>
                                    <textarea name="Speakers[${index}].Description" class="form-control" rows="4" placeholder="Descrierea speaker-ului" required></textarea>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Imagine speaker</label>
                                    <input name="Speakers[${index}].Image" type="file" class="form-control" accept="image/*" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
        });

        document.getElementById('speakersContainer').addEventListener('click', function (e) {
            var btn = e.target.closest('.remove-speaker');
            if (!btn) return;
            btn.closest('.speaker-item').remove();
            // Re-index speakers
            var items = document.querySelectorAll('.speaker-item');
            items.forEach(function (item, idx) {
                item.dataset.index = idx;
                item.querySelector('.speaker-number').textContent = idx + 1;
                item.querySelectorAll('[name]').forEach(function (input) {
                    input.name = input.name.replace(/Speakers\[\d+\]/, 'Speakers[' + idx + ']');
                });
                // Show/hide remove button (always show if more than 1)
                var removeBtn = item.querySelector('.remove-speaker');
                if (removeBtn) removeBtn.style.display = items.length > 1 ? '' : 'none';
            });
        });
    </script>
}
