@model CareerRookies.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Bine ai venit în panoul de administrare</h1>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-start border-primary border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-calendar-event fs-1 text-primary"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.WorkshopCount</h2>
                            <p class="text-muted mb-0">Workshop-uri totale</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-start border-success border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-calendar-check fs-1 text-success"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.UpcomingWorkshopCount</h2>
                            <p class="text-muted mb-0">Workshop-uri viitoare</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-start border-warning border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-file-earmark-text fs-1 text-warning"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.PendingArticles</h2>
                            <p class="text-muted mb-0">Articole în așteptare</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-start border-info border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-people fs-1 text-info"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.TotalRegistrations</h2>
                            <p class="text-muted mb-0">Înregistrări totale</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-start border-secondary border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-chat-quote fs-1 text-secondary"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.TestimonialCount</h2>
                            <p class="text-muted mb-0">Testimoniale</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-start border-danger border-4 h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="bi bi-link-45deg fs-1 text-danger"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h2 class="mb-0">@Model.ResourceCount</h2>
                            <p class="text-muted mb-0">Resurse</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
