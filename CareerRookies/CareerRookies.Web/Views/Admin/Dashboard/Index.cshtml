@model CareerRookies.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h1 class="h4 mb-4">Dashboard</h1>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <a href="/Admin/Workshops" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-calendar-event fs-3 text-primary"></i>
                        <div class="fs-2 fw-bold mt-1">@Model.WorkshopCount</div>
                        <small class="text-muted">Workshop-uri</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <a href="/Admin/Workshops" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-calendar-check fs-3 text-success"></i>
                        <div class="fs-2 fw-bold mt-1">@Model.UpcomingWorkshopCount</div>
                        <small class="text-muted">Viitoare</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <a href="/Admin/Articles" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 @(Model.PendingArticles > 0 ? "border-start border-warning border-3" : "")">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-file-earmark-text fs-3 text-warning"></i>
                        <div class="fs-2 fw-bold mt-1">@Model.PendingArticles</div>
                        <small class="text-muted">Articole noi</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-3">
                    <i class="bi bi-people fs-3 text-info"></i>
                    <div class="fs-2 fw-bold mt-1">@Model.TotalRegistrations</div>
                    <small class="text-muted">Înregistrări</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <a href="/Admin/Testimonials" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-chat-quote fs-3 text-secondary"></i>
                        <div class="fs-2 fw-bold mt-1">@Model.TestimonialCount</div>
                        <small class="text-muted">Testimoniale</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-4 col-xl-2">
            <a href="/Admin/Resources" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <i class="bi bi-link-45deg fs-3 text-danger"></i>
                        <div class="fs-2 fw-bold mt-1">@Model.ResourceCount</div>
                        <small class="text-muted">Resurse</small>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h6 class="fw-bold mb-3">Acțiuni rapide</h6>
            <div class="d-flex flex-wrap gap-2">
                <a href="/Admin/Workshops/Create" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i> Workshop nou
                </a>
                <a href="/Admin/Testimonials/Create" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i> Testimonial nou
                </a>
                <a href="/Admin/Resources/Create" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i> Resursă nouă
                </a>
                <a href="/Admin/StudentClasses" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-people me-1"></i> Clase elevi
                </a>
                <a href="/Admin/Settings" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-gear me-1"></i> Setări
                </a>
            </div>
        </div>
    </div>
</div>
