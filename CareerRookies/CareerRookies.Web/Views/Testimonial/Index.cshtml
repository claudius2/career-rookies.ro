@model List<Testimonial>
@{
    ViewData["Title"] = "Testimoniale";
}

<section class="page-section section-cream">
    <div class="container">
        <div class="section-title">
            <h2>Testimoniale</h2>
            <p>Ce spun elevii și speakerii despre experiența lor cu Career Rookies.</p>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var testimonial in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-cr testimonial-card h-100">
                            <p class="testimonial-text">"@testimonial.Text"</p>
                            <div class="testimonial-author">@testimonial.AuthorName</div>
                            <div class="testimonial-role mb-2">
                                @(testimonial.AuthorType == AuthorType.Student ? "Elev" : "Speaker")
                            </div>
                            <span class="@(testimonial.AuthorType == AuthorType.Student ? "badge-student" : "badge-employer")" style="display: inline-block; margin: 0 auto;">
                                @(testimonial.AuthorType == AuthorType.Student ? "Elev" : "Speaker")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-quote" style="font-size: 4rem; color: var(--cr-primary); opacity: 0.4;"></i>
                <p class="mt-3 fs-5" style="color: #666;">Nu există testimoniale momentan.</p>
            </div>
        }
    </div>
</section>
