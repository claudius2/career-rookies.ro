@model CareerRookies.Web.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Acasă";
}

<!-- Hero Carousel -->
<section class="hero-section">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active" style="min-height: 550px; background: linear-gradient(135deg, #5B1A4A 0%, #C2185B 100%);">
                <div class="hero-content">
                    <h1>Construiește-ți viitorul profesional</h1>
                    <p>Descoperă workshop-uri interactive, resurse valoroase și oportunități reale pentru cariera ta.</p>
                    <a asp-controller="Workshop" asp-action="Upcoming" class="btn btn-secondary-cr btn-lg">
                        <i class="bi bi-calendar-event me-2"></i>Vezi Workshop-uri
                    </a>
                </div>
            </div>
            <div class="carousel-item" style="min-height: 550px; background: linear-gradient(135deg, #C2185B 0%, #EF6C00 100%);">
                <div class="hero-content">
                    <h1>Învață de la profesioniști</h1>
                    <p>Participă la workshop-uri susținute de experți din industrie și descoperă-ți pasiunile.</p>
                    <a asp-controller="Workshop" asp-action="Upcoming" class="btn btn-secondary-cr btn-lg">
                        <i class="bi bi-people me-2"></i>Descoperă Speakerii
                    </a>
                </div>
            </div>
            <div class="carousel-item" style="min-height: 550px; background: linear-gradient(135deg, #EF6C00 0%, #FFC107 100%);">
                <div class="hero-content">
                    <h1>Fii pregătit pentru viitor</h1>
                    <p>Accesează resurse, articole și ghiduri create special pentru dezvoltarea ta profesională.</p>
                    <a asp-controller="Resource" asp-action="Index" class="btn btn-primary-cr btn-lg">
                        <i class="bi bi-book me-2"></i>Explorează Resurse
                    </a>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Următor</span>
        </button>
    </div>
</section>

<!-- Despre Noi -->
<section class="page-section section-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="section-title" style="text-align: left;">
                    <h2>Despre Noi</h2>
                </div>
                <p class="lead" style="color: var(--cr-primary-dark);">
                    Career Rookies este o inițiativă dedicată elevilor din România care își doresc să-și construiască un viitor profesional de succes.
                </p>
                <p>
                    Misiunea noastră este să oferim tinerilor acces la workshop-uri, resurse și mentorat din partea profesioniștilor
                    din diverse domenii. Credem că fiecare elev merită să aibă acces la informații și oportunități care să-l ajute
                    să ia cele mai bune decizii pentru cariera sa.
                </p>
                <p>
                    Prin evenimentele și resursele noastre, conectăm elevii cu experți din industrie, consilieri de carieră și
                    programe educaționale care le deschid noi perspective.
                </p>
                <a asp-controller="Workshop" asp-action="Upcoming" class="btn btn-primary-cr mt-2">
                    <i class="bi bi-arrow-right me-2"></i>Află mai multe
                </a>
            </div>
            <div class="col-lg-6">
                <div class="card-cr p-4 p-lg-5 text-center" style="background: linear-gradient(135deg, rgba(91,26,74,0.08), rgba(194,24,91,0.08));">
                    <i class="bi bi-people-fill" style="font-size: 5rem; color: var(--cr-primary);"></i>
                    <p class="mt-3 fw-semibold fs-5" style="color: var(--cr-primary-dark);">Comunitatea Career Rookies</p>
                    <p class="text-muted mb-0">Workshop-uri · Mentorat · Resurse · Comunitate</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Workshop-uri Viitoare -->
<section class="page-section section-cream">
    <div class="container">
        <div class="section-title">
            <h2>Workshop-uri Viitoare</h2>
            <p>Participă la evenimentele noastre și dezvoltă-ți abilitățile profesionale</p>
        </div>
        @if (Model.UpcomingWorkshops.Any())
        {
            <div class="row g-4">
                @foreach (var workshop in Model.UpcomingWorkshops)
                {
                    <div class="col-md-4">
                        <div class="card card-cr workshop-card h-100">
                            @if (!string.IsNullOrEmpty(workshop.ImagePath))
                            {
                                <img src="@workshop.ImagePath" class="card-img-top" alt="@workshop.Title">
                            }
                            else
                            {
                                <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 200px; background: linear-gradient(135deg, #5B1A4A, #C2185B);">
                                    <i class="bi bi-easel text-white" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <span class="workshop-date">
                                <i class="bi bi-calendar3 me-1"></i>@workshop.Date.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("ro-RO"))
                            </span>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@workshop.Title</h5>
                                <div class="workshop-meta">
                                    <span><i class="bi bi-person-fill me-1"></i>@workshop.SpeakerNames</span>
                                </div>
                                <p class="card-text">
                                    @TextHelper.Truncate(workshop.Description, 120)
                                </p>
                                <div class="mt-auto pt-2">
                                    <a asp-controller="Workshop" asp-action="Detail" asp-route-id="@workshop.Id" class="btn btn-primary-cr">
                                        Detalii <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-5">
                <a asp-controller="Workshop" asp-action="Upcoming" class="btn btn-outline-cr">
                    Vezi toate workshop-urile <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-calendar-x" style="font-size: 4rem; color: var(--cr-primary); opacity: 0.3;"></i>
                <p class="mt-3 fs-5" style="color: var(--cr-text);">Nu există workshop-uri planificate momentan.</p>
                <p class="text-muted">Revino în curând pentru noi evenimente!</p>
            </div>
        }
    </div>
</section>

<!-- Opinii / Testimoniale -->
<section class="page-section section-white">
    <div class="container">
        <div class="section-title">
            <h2>Ce spun participanții</h2>
            <p>Opiniile elevilor și speakerilor despre experiența Career Rookies</p>
        </div>
        @if (Model.Testimonials.Any())
        {
            <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6000">
                <div class="carousel-inner">
                    @for (int i = 0; i < Model.Testimonials.Count; i++)
                    {
                        var testimonial = Model.Testimonials[i];
                        <div class="carousel-item @(i == 0 ? "active" : "")">
                            <div class="row justify-content-center">
                                <div class="col-lg-8 col-xl-6">
                                    <div class="card card-cr testimonial-card">
                                        <p class="testimonial-text">"@testimonial.Text"</p>
                                        <div class="testimonial-author">@testimonial.AuthorName</div>
                                        <div class="mt-2">
                                            <span class="@(testimonial.AuthorType == AuthorType.Student ? "badge-student" : "badge-employer")">
                                                @(testimonial.AuthorType == AuthorType.Student ? "Elev" : "Speaker")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                @if (Model.Testimonials.Count > 1)
                {
                    <div class="text-center mt-4">
                        <button class="btn btn-outline-cr btn-sm me-2" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <button class="btn btn-outline-cr btn-sm" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted">Nu există testimoniale momentan.</p>
        }
    </div>
</section>

