@using CareerRookies.Web.ViewModels
@model PagedResult<Article>
@{
    ViewData["Title"] = "Cautare";
    var query = ViewBag.Query as string ?? "";
}

<section class="page-section">
    <div class="container">
        <div class="section-title">
            <h2>Cautare</h2>
        </div>

        <form method="get" asp-controller="Home" asp-action="Search" class="mb-4">
            <div class="input-group input-group-lg">
                <input type="text" name="q" value="@query" class="form-control" placeholder="Cauta articole..." />
                <button type="submit" class="btn btn-primary-cr">
                    <i class="bi bi-search"></i> Cauta
                </button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(query))
        {
            <p class="text-muted mb-4">@Model.TotalCount rezultate pentru "<strong>@query</strong>"</p>

            @if (Model.Items.Any())
            {
                <div class="row g-4">
                    @foreach (var article in Model.Items)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card card-cr h-100">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@article.Title</h5>
                                    <div class="article-meta mb-2">
                                        <span><i class="bi bi-person me-1"></i>@article.AuthorName</span>
                                        <span><i class="bi bi-calendar3 me-1"></i>@article.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    </div>
                                    <p class="card-text">
                                        @{
                                            var plain = System.Text.RegularExpressions.Regex.Replace(article.Content, "<.*?>", "");
                                            @(plain.Length > 200 ? plain[..200] + "..." : plain)
                                        }
                                    </p>
                                    <div class="mt-auto">
                                        <a asp-controller="Article" asp-action="Detail" asp-route-id="@article.Id" class="btn btn-outline-cr">
                                            Citeste <i class="bi bi-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <partial name="_Pagination" model="@(Model.Page, Model.TotalPages, "Search", "Home", new { q = query })" />
            }
        }
    </div>
</section>
