@model CareerRookies.Web.ViewModels.ArticleSubmitViewModel
@{
    ViewData["Title"] = "Trimite un Articol";
}

<section class="page-section section-cream">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="section-title">
                    <h2>Trimite un Articol</h2>
                    <p>
                        Ai o poveste de împărtășit sau sfaturi utile pentru colegii tăi? Scrie un articol și echipa noastră
                        îl va revizui pentru publicare.
                    </p>
                </div>

                <div class="card card-cr">
                    <div class="card-body p-4 p-md-5">
                        <form asp-controller="Article" asp-action="Submit" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Title" class="form-label"></label>
                                <input asp-for="Title" class="form-control form-control-lg" placeholder="Titlul articolului" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="AuthorName" class="form-label"></label>
                                <input asp-for="AuthorName" class="form-control form-control-lg" placeholder="Numele tău" />
                                <span asp-validation-for="AuthorName" class="text-danger"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Content" class="form-label"></label>
                                <textarea asp-for="Content" class="form-control" rows="10" placeholder="Scrie conținutul articolului aici..."></textarea>
                                <span asp-validation-for="Content" class="text-danger"></span>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary-cr btn-lg">
                                    <i class="bi bi-send me-2"></i>Trimite articolul
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a asp-controller="Article" asp-action="Index" class="btn btn-outline-cr">
                        <i class="bi bi-arrow-left me-1"></i>Înapoi la articole
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
