@model List<Article>
@{
    ViewData["Title"] = "Articole";
}

<section class="page-section section-cream">
    <div class="container">
        <div class="section-title">
            <h2>Articole</h2>
            <p>Descoperă povești, sfaturi și experiențe împărtășite de comunitatea Career Rookies.</p>
        </div>

        <div class="text-center mb-5">
            <a asp-controller="Article" asp-action="Submit" class="btn btn-primary-cr">
                <i class="bi bi-pencil-square me-1"></i>Trimite un articol
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="row g-4">
                @foreach (var article in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-cr article-card h-100">
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 180px; background: linear-gradient(135deg, var(--cr-primary) 0%, var(--cr-primary-dark) 100%);">
                                <i class="bi bi-journal-richtext text-white" style="font-size: 3rem; opacity: 0.6;"></i>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@article.Title</h5>
                                <div class="article-meta mb-3">
                                    <span><i class="bi bi-person me-1"></i>@article.AuthorName</span>
                                    <span><i class="bi bi-calendar3 me-1"></i>@article.CreatedAt.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("ro-RO"))</span>
                                </div>
                                <p class="card-text">
                                    @{
                                        var plainText = System.Text.RegularExpressions.Regex.Replace(article.Content, "<.*?>", "");
                                        @(plainText.Length > 200 ? plainText.Substring(0, 200) + "..." : plainText)
                                    }
                                </p>
                                <div class="mt-auto">
                                    <a asp-controller="Article" asp-action="Detail" asp-route-id="@article.Id" class="btn btn-outline-cr">
                                        <i class="bi bi-book me-1"></i>Citește
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-x" style="font-size: 4rem; color: var(--cr-primary); opacity: 0.4;"></i>
                <p class="mt-3 fs-5" style="color: #666;">Nu există articole momentan.</p>
                <a asp-controller="Article" asp-action="Submit" class="btn btn-primary-cr mt-2">Fii primul care scrie un articol</a>
            </div>
        }
    </div>
</section>
