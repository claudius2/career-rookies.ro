@model ErrorViewModel
@{
    ViewData["Title"] = "Eroare";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="py-5">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                    <h1 class="section-title mt-4 mb-3">Oops! A apărut o eroare.</h1>
                    <p class="text-muted fs-5 mb-4">
                        Ne pare rău, dar ceva nu a funcționat corect. Te rugăm să încerci din nou.
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <p class="text-muted small">
                            <strong>Request ID:</strong> <code>@Model.RequestId</code>
                        </p>
                    }

                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary-cr btn-lg mt-3">
                        <i class="bi bi-house me-2"></i>Înapoi la pagina principală
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
