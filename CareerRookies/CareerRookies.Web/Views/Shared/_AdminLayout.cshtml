<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Career Rookies</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 250px;
            height: 100vh;
            background-color: #5B1A4A;
            color: #fff;
            overflow-y: auto;
            z-index: 1040;
            display: flex;
            flex-direction: column;
        }

        .admin-sidebar .nav-link {
            color: rgba(255, 255, 255, 0.75);
            padding: 0.6rem 1.25rem;
            border-radius: 0;
            transition: background-color 0.2s, color 0.2s;
        }

        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            color: #fff;
            background-color: rgba(255, 255, 255, 0.1);
        }

        .admin-sidebar .nav-link i {
            width: 24px;
            text-align: center;
            margin-right: 0.5rem;
        }

        .admin-content {
            margin-left: 250px;
            padding: 2rem;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body class="admin-body">
    <!-- Sidebar -->
    <nav class="admin-sidebar">
        <!-- Brand -->
        <div class="p-3 border-bottom border-light border-opacity-25">
            <a href="/" class="text-white text-decoration-none d-flex align-items-center">
                <img src="/images/logo.jpeg" height="32" alt="Career Rookies" class="me-2" />
                <span class="fw-bold">Career Rookies</span>
            </a>
        </div>

        <!-- Navigation -->
        <ul class="nav flex-column mt-3 flex-grow-1">
            <li class="nav-item">
                <a class="nav-link" href="/Admin">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Workshops">
                    <i class="bi bi-calendar-event"></i> Workshop-uri
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Articles">
                    <i class="bi bi-newspaper"></i> Articole
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Testimonials">
                    <i class="bi bi-chat-quote"></i> Testimoniale
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Resources">
                    <i class="bi bi-file-earmark-text"></i> Resurse
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/StudentClasses">
                    <i class="bi bi-people"></i> Clase elevi
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Settings">
                    <i class="bi bi-gear"></i> Setări
                </a>
            </li>
        </ul>

        <!-- Bottom links -->
        <div class="border-top border-light border-opacity-25 p-3">
            <a href="/" class="nav-link text-white-50 small">
                <i class="bi bi-arrow-left me-1"></i> &#xCE;napoi pe site
            </a>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" class="mt-2">
                <button type="submit" class="nav-link text-white-50 small btn btn-link p-0 text-decoration-none">
                    <i class="bi bi-box-arrow-right me-1"></i> Deconectare
                </button>
            </form>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="admin-content">
        <!-- TempData Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
