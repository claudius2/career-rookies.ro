@{
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | Career Rookies</title>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <!-- Mobile Sidebar Toggle -->
    <button class="btn btn-primary d-lg-none position-fixed"
            data-toggle-sidebar
            style="top: 10px; left: 10px; z-index: 1060; border-radius: 8px; padding: 0.4rem 0.7rem;">
        <i class="bi bi-list fs-5"></i>
    </button>

    <!-- Sidebar -->
    <nav class="admin-sidebar d-flex flex-column">
        <!-- Brand -->
        <div class="px-3 py-2 border-bottom border-light border-opacity-25">
            <a href="/Admin" class="text-white text-decoration-none fw-bold d-flex align-items-center">
                <i class="bi bi-grid-fill me-2"></i> CR Admin
            </a>
        </div>

        <!-- Navigation -->
        <ul class="nav flex-column mt-2 flex-grow-1">
            <li class="nav-item">
                <a class="nav-link @(currentPath == "/admin" ? "active" : "")" href="/Admin">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/workshops") ? "active" : "")" href="/Admin/Workshops">
                    <i class="bi bi-calendar-event"></i> Workshop-uri
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/articles") ? "active" : "")" href="/Admin/Articles">
                    <i class="bi bi-newspaper"></i> Articole
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/testimonials") ? "active" : "")" href="/Admin/Testimonials">
                    <i class="bi bi-chat-quote"></i> Testimoniale
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/resources") ? "active" : "")" href="/Admin/Resources">
                    <i class="bi bi-file-earmark-text"></i> Resurse
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/studentclasses") ? "active" : "")" href="/Admin/StudentClasses">
                    <i class="bi bi-people"></i> Clase elevi
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentPath.StartsWith("/admin/settings") ? "active" : "")" href="/Admin/Settings">
                    <i class="bi bi-gear"></i> Setări
                </a>
            </li>
        </ul>

        <!-- Bottom links -->
        <div class="border-top border-light border-opacity-25 p-3">
            <a href="/" class="nav-link text-white-50 small" target="_blank">
                <i class="bi bi-box-arrow-up-right me-1"></i> Vezi site
            </a>
            <form method="post" action="/deconectare" class="mt-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="/" />
                <button type="submit" class="nav-link text-white-50 small btn btn-link p-0 text-decoration-none">
                    <i class="bi bi-box-arrow-right me-1"></i> Deconectare
                </button>
            </form>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="admin-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
