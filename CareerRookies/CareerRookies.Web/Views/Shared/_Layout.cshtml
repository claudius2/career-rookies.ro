<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Career Rookies</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- TempData Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg bg-white shadow-sm fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="/images/logo.jpeg" height="40" alt="Career Rookies" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Acasă</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Workshop-uri
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Workshop" asp-action="Upcoming">Viitoare</a></li>
                                <li><a class="dropdown-item" asp-controller="Workshop" asp-action="Past">Trecute</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Article" asp-action="Index">Articole</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Testimonial" asp-action="Index">Testimoniale</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Resource" asp-action="Index">Resurse</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main role="main" style="padding-top: 70px;">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5>Career Rookies</h5>
                    <p>Ajutăm liceenii să descopere lumea profesională prin workshop-uri interactive,
                        resurse educative și oportunități reale de dezvoltare.</p>
                </div>
                <div class="col-lg-4">
                    <h5>Link-uri rapide</h5>
                    <ul class="footer-links">
                        <li><a href="/">Acasă</a></li>
                        <li><a asp-controller="Workshop" asp-action="Upcoming">Workshop-uri</a></li>
                        <li><a asp-controller="Article" asp-action="Index">Articole</a></li>
                        <li><a asp-controller="Testimonial" asp-action="Index">Testimoniale</a></li>
                        <li><a asp-controller="Resource" asp-action="Index">Resurse</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h5>Contact</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>contact@@careerrookies.ro</li>
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>București, România</li>
                    </ul>
                    <div class="footer-social mt-3">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
                <span>&copy; 2026 Career Rookies. Toate drepturile rezervate.</span>
                <div class="mt-2 mt-md-0">
                    <a asp-controller="Legal" asp-action="Terms" class="me-3">Termeni</a>
                    <a asp-controller="Legal" asp-action="Privacy" class="me-3">Confidențialitate</a>
                    <a asp-controller="Legal" asp-action="Cookies">Cookies</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Cookie Consent Bar -->
    <div id="cookieConsent" class="cookie-consent-bar hidden">
        <p>
            Acest site folosește cookies pentru a îmbunătăți experiența de navigare.
            <a asp-controller="Legal" asp-action="Cookies">Află mai multe</a>.
        </p>
        <button class="btn-accept-cookies" >Accept</button>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
