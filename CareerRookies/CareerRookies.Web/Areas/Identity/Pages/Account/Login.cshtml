@page "/autentificare"
@model CareerRookies.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Autentificare";
}

<section style="min-height: calc(100vh - 95px); display: flex; align-items: center; background: linear-gradient(135deg, rgba(91,26,74,0.05) 0%, rgba(194,24,91,0.08) 50%, rgba(255,193,7,0.05) 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 col-sm-10">

                <!-- Logo -->
                <div class="text-center mb-4">
                    <a href="/">
                        <img src="/images/logo.png" height="55" alt="Career Rookies" />
                    </a>
                    <h2 class="mt-3 fw-bold" style="color: var(--cr-primary-dark); font-family: var(--cr-font-heading);">
                        Bine ai revenit!
                    </h2>
                    <p class="text-muted">Autentifică-te pentru a accesa panoul de administrare.</p>
                </div>

                <!-- Login Card -->
                <div class="card shadow-lg border-0" style="border-radius: var(--cr-radius);">
                    <div class="card-body p-4 p-md-5">

                        <form id="account" method="post" asp-page="/Account/Login" asp-area="Identity" asp-route-returnUrl="@Model.ReturnUrl">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="border-radius: var(--cr-radius-sm);"></div>

                            <!-- Email -->
                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label fw-semibold" style="color: var(--cr-primary-dark);">
                                    <i class="bi bi-envelope me-1"></i>Email
                                </label>
                                <input asp-for="Input.Email" class="form-control form-control-lg" placeholder="exemplu@email.com"
                                       style="border-radius: var(--cr-radius-sm); border-color: #ddd;"
                                       autocomplete="username" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label fw-semibold" style="color: var(--cr-primary-dark);">
                                    <i class="bi bi-lock me-1"></i>Parolă
                                </label>
                                <div class="input-group">
                                    <input asp-for="Input.Password" class="form-control form-control-lg" placeholder="Introdu parola"
                                           style="border-radius: var(--cr-radius-sm) 0 0 var(--cr-radius-sm); border-color: #ddd;"
                                           autocomplete="current-password" />
                                    <button class="btn btn-outline-secondary" type="button" id="togglePassword"
                                            style="border-radius: 0 var(--cr-radius-sm) var(--cr-radius-sm) 0; border-color: #ddd;">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <!-- Remember Me -->
                            <div class="mb-4">
                                <div class="form-check">
                                    <input type="checkbox" asp-for="Input.RememberMe" class="form-check-input" style="border-color: var(--cr-primary);" />
                                    <label asp-for="Input.RememberMe" class="form-check-label" style="color: #666;">
                                        Ține-mă minte
                                    </label>
                                </div>
                            </div>

                            <!-- Submit -->
                            <div class="d-grid">
                                <button type="submit" class="btn btn-lg text-white fw-semibold"
                                        style="background: linear-gradient(135deg, var(--cr-primary) 0%, var(--cr-primary-dark) 100%); border: none; border-radius: var(--cr-radius-sm); padding: 0.8rem;">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Autentificare
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Back to site -->
                <div class="text-center mt-4">
                    <a href="/" class="text-muted text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i>Înapoi pe site
                    </a>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function () {
            var input = document.getElementById('Input_Password');
            var icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    </script>
}
