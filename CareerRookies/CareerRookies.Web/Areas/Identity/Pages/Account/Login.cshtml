@page "/autentificare"
@model CareerRookies.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Autentificare";
}

<section style="min-height: calc(100vh - 95px); display: flex; align-items: center; justify-content: center;">
    <div style="width: 100%; max-width: 420px; padding: 1rem;">
        <div class="text-center mb-4">
            <a href="/">
                <img src="/images/logo.png" height="60" alt="Career Rookies" />
            </a>
            <p class="text-muted mt-2">Autentifică-te pentru a continua</p>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                    @if (Model.ErrorMessage != null)
                    {
                        <div class="alert alert-danger py-2">@Model.ErrorMessage</div>
                    }

                    @{
                        var errors = ViewData.ModelState[string.Empty]?.Errors;
                    }
                    @if (errors != null && errors.Count > 0)
                    {
                        <div class="alert alert-danger py-2">
                            @foreach (var error in errors)
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <div class="mb-3">
                        <label for="Input_Email" class="form-label">Email</label>
                        <input type="email" id="Input_Email" name="Input.Email"
                               value="@Model.Input.Email"
                               class="form-control" placeholder="exemplu@@email.com"
                               autocomplete="username" required />
                        <span class="text-danger small">
                            @Html.ValidationMessage("Input.Email")
                        </span>
                    </div>

                    <div class="mb-3">
                        <label for="Input_Password" class="form-label">Parolă</label>
                        <input type="password" id="Input_Password" name="Input.Password"
                               class="form-control" placeholder="Introdu parola"
                               autocomplete="current-password" required />
                        <span class="text-danger small">
                            @Html.ValidationMessage("Input.Password")
                        </span>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" id="Input_RememberMe" name="Input.RememberMe" value="true"
                               class="form-check-input" @(Model.Input.RememberMe ? "checked" : "") />
                        <label for="Input_RememberMe" class="form-check-label">Ține-mă minte</label>
                    </div>

                    <button type="submit" class="btn btn-primary-cr w-100">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Autentificare
                    </button>
                </form>
            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/" class="text-muted text-decoration-none small">
                <i class="bi bi-arrow-left me-1"></i>Înapoi pe site
            </a>
        </div>
    </div>
</section>
