@page "/acces-interzis"
@model CareerRookies.Web.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acces interzis";
}

<section class="page-section section-white">
    <div class="container text-center py-5">
        <i class="bi bi-shield-exclamation" style="font-size: 4rem; color: var(--cr-accent);"></i>
        <h2 class="mt-3 fw-bold" style="color: var(--cr-primary-dark);">Acces interzis</h2>
        <p class="text-muted fs-5">Nu ai permisiunea necesară pentru a accesa această pagină.</p>
        <a href="/" class="btn btn-primary-cr mt-3">
            <i class="bi bi-house me-1"></i>Înapoi acasă
        </a>
    </div>
</section>
